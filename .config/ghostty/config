theme = "Kanagawa Wave"
background-opacity = 0.95

font-size = 12
font-family = "Fira Code"
font-family-bold = "Fira Code"
font-family-italic = "Fira Code"
font-family-bold-italic = "Fira Code"
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss07
font-feature = ss08
font-feature = zero
font-feature = onum

app-notifications = no-clipboard-copy

keybind = ctrl+shift+n=unbind
keybind = ctrl+shift+p=unbind
keybind = ctrl+,=unbind
